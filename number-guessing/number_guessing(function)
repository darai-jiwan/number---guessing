import random 

def playgame(count, start, end):
    chance = count 
    ran = random.randint(start,end)
    print(f"You got total {chance} chance to guess the number, So do your best.")
    while chance >0:
        try:
            player_num = int(input(f"Choose a number between {start}-{end}."))
            if player_num == ran:
                print(f"!!! Correct guess!!! Congratualtion")
                return
            elif player_num > ran:
                print("Lower")
                chance -=1
                print(f"You have {chance} chance left.")
            elif player_num < ran:
                print("Higher")
                chance -=1
                print(f"You have {chance} chance left.")  
        except ValueError:
            print("Invalid Input Please Enter a valid number.")
            continue
        
    print(f"Game over. The correct number is {ran}.")

